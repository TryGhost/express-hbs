{
  "name": "express-hbs",
  "version": "2.5.0",
  "description": "Express handlebars template engine complete with multiple layouts, partials and blocks.",
  "keywords": [
    "express4",
    "express",
    "handlebars",
    "layout",
    "partials"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "directories": {
    "example": "example"
  },
  "scripts": {
    "lint": "oxlint --quiet && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "test": "mocha",
    "posttest": "pnpm lint",
    "coverage": "nyc --check-coverage mocha",
    "preship": "pnpm test",
    "ship": "pro-ship"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TryGhost/express-hbs"
  },
  "bugs": "https://github.com/TryGhost/express-hbs/issues",
  "author": "Mario Gutierrez <mario@barc.com>",
  "license": "MIT",
  "devDependencies": {
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "i18n": "0.15.3",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "rewire": "9.0.1",
    "supertest": "7.2.2"
  },
  "dependencies": {
    "@tryghost/pro-ship": "1.1.5",
    "handlebars": "4.7.9",
    "lodash": "4.18.1",
    "readdirp": "5.0.0"
  },
  "optionalDependencies": {
    "js-beautify": "^2.0.0"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af"
}
