{
  "name": "express-hbs",
  "version": "3.0.0",
  "description": "Express handlebars template engine complete with multiple layouts, partials and blocks.",
  "keywords": [
    "express4",
    "express",
    "handlebars",
    "layout",
    "partials"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "directories": {
    "example": "example"
  },
  "scripts": {
    "lint": "oxlint --quiet && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "test": "mocha",
    "posttest": "pnpm lint",
    "coverage": "nyc --check-coverage mocha",
    "preship": "pnpm test",
    "ship": "pro-ship"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TryGhost/express-hbs"
  },
  "bugs": "https://github.com/TryGhost/express-hbs/issues",
  "author": "Mario Gutierrez <mario@barc.com>",
  "license": "MIT",
  "devDependencies": {
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "i18n": "0.15.3",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "rewire": "9.0.1",
    "supertest": "7.2.2"
  },
  "dependencies": {
    "@tryghost/pro-ship": "1.1.5",
    "handlebars": "4.7.9",
    "lodash": "4.18.1",
    "readdirp": "3.6.0"
  },
  "optionalDependencies": {
    "js-beautify": "^2.0.0"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e"
}
